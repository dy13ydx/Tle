gsettings set org.mate.Marco.global-keybindings switch-windows '<Alt>grave'
gsettings set org.mate.Marco.global-keybindings switch-group 'disabled'
gsettings set org.mate.panel.toplevel:/org/mate/panel/toplevels/bottom/ auto-hide true
gsettings set org.mate.terminal.profile:/org/mate/terminal/profiles/profile0/ default-show-menubar false
gsettings set org.mate.terminal.profile:/org/mate/terminal/profiles/profile0/ allow-bold true
curl -sO https://raw.githubusercontent.com/dy13ydx/Tle/refs/heads/master/.tmux.conf
curl -sO https://raw.githubusercontent.com/dy13ydx/Tle/refs/heads/master/.inputrc
curl -sO https://raw.githubusercontent.com/dy13ydx/Tle/refs/heads/master/.vimrc
mkdir -p ~/.config/nvim && curl -s https://raw.githubusercontent.com/dy13ydx/Tle/refs/heads/master/init.vim -o ~/.config/nvim/init.vim
[[ $- == *i* ]] && bind -f ~/.inputrc
mkdir -p ~/.config/bin ~/.local/bin
curl -s https://raw.githubusercontent.com/dy13ydx/Tle/refs/heads/master/target -o ~/.local/bin/target && chmod +x ~/.local/bin/target
curl -s https://raw.githubusercontent.com/dy13ydx/Tle/refs/heads/master/yxp -o ~/.local/bin/yxp && chmod +x ~/.local/bin/yxp
curl -s https://raw.githubusercontent.com/dy13ydx/Tle/refs/heads/master/ryxp -o ~/.local/bin/yxp && chmod +x ~/.local/bin/ryxp
curl -s https://raw.githubusercontent.com/dy13ydx/Tle/refs/heads/master/mkenv -o ~/.local/bin/mkenv && chmod +x ~/.local/bin/mkenv
curl -s https://raw.githubusercontent.com/ryanwoodsmall/static-binaries/refs/heads/master/x86_64/rlwrap -o ~/.local/bin/rlwrap && chmod +x ~/.local/bin/rlwrap
curl -LsSf https://astral.sh/uv/install.sh | sh
mkdir -p ~/dy13ydx && cd ~/dy13ydx
curl -sLOJ https://github.com/peteretelej/tree/releases/download/v1.3.0/tree-v1.3.0-Linux-amd64.tar.gz
tar xvzf tree-v1.3.0-Linux-amd64.tar.gz -C ~/.local/bin && chmod +x ~/.local/bin/tree && rm -f tree-v1.3.0-Linux-amd64.tar.gz
curl -sOJ https://raw.githubusercontent.com/int0x33/nc.exe/master/nc64.exe
curl -sOJ https://raw.githubusercontent.com/dy13ydx/Tle/refs/heads/master/vimium.json
curl -sOJ https://raw.githubusercontent.com/dy13ydx/Tle/refs/heads/master/user.js
firefox https://addons.mozilla.org/en-GB/firefox/addon/vimium-ff/ </dev/null >/dev/null 2>&1
for d in ~/.mozilla/firefox/*.default*/; do cp user.js "$d"; done
setsid mate-terminal --disable-factory --maximize -- bash -c "cd ~/dy13ydx && exec tmux" </dev/null >/dev/null 2>&1 & (sleep 1 && kill -HUP $PPID) &
